OPEN_API_KEY=sk-proj-...  # OpenAI API key for chat

# Supabase (recommended): set both for persistence. Get URL via MCP get_project_url.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: set to 1 to disable Supabase and use in-memory store only (data lost on restart)
# USE_IN_MEMORY_ONLY=1
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here # optional

# Pinecone (for RAG): company index = di-company-knowledge-dev, domain = di-domain-knowledge-dev
PINECONE_API_KEY=your_pinecone_api_key_here
# Optional: index name (e.g. di-company-knowledge-dev) or full host URL. Name is resolved via describe_index.
# PINECONE_COMPANY_INDEX_HOST=di-company-knowledge-dev
# PINECONE_DOMAIN_INDEX_HOST=di-domain-knowledge-dev
# Optional: embedding dimension to match your Pinecone index (e.g. 512). Default 1536 (text-embedding-3-small).
# PINECONE_EMBEDDING_DIMENSION=512
