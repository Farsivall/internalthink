OPEN_API_KEY=sk-proj-...  # OpenAI API key for chat

# Supabase (recommended): set both for persistence. Get URL via MCP get_project_url.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: set to 1 to disable Supabase and use in-memory store only (data lost on restart)
# USE_IN_MEMORY_ONLY=1
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here # optional
